{
  "name": "gitgate-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "GitGate — local-first runner for GitHub Actions workflows",
  "homepage": "https://github.com/plsft/gitgate#readme",
  "bugs": "https://github.com/plsft/gitgate/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plsft/gitgate.git"
  },
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "pipelines:compile": "tsx cli/src/index.ts ci compile",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "@gitgate/ci": "workspace:*",
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
