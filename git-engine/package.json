{
  "name": "@gitgate/git-core",
  "version": "0.2.1",
  "description": "Pure-TypeScript git protocol: objects, packfiles, smart-HTTP, diff, merge, refs",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@types/pako": "^2.0.4",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "git",
    "git-protocol",
    "smart-http",
    "packfile",
    "typescript",
    "cloudflare-workers"
  ],
  "homepage": "https://github.com/plsft/gitgate/tree/main/git-engine#readme",
  "bugs": "https://github.com/plsft/gitgate/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plsft/gitgate.git",
    "directory": "git-engine"
  },
  "author": "plsft"
}
