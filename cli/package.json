{
  "name": "@rehearse/cli",
  "version": "0.6.7",
  "description": "Rehearse — local-first GitHub Actions runner + TypeScript-pipeline CLI. Single binary `rh`.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "rh": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@rehearse/ci": "workspace:*",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "tsx": "^4.19.2",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "github-actions",
    "ci",
    "runner",
    "local-ci",
    "act-alternative",
    "typescript",
    "pipeline"
  ],
  "homepage": "https://github.com/plsft/rehearse/tree/main/cli#readme",
  "bugs": "https://github.com/plsft/rehearse/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plsft/rehearse.git",
    "directory": "cli"
  },
  "author": "plsft"
}
