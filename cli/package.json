{
  "name": "@gitgate/cli",
  "version": "0.1.0",
  "description": "GitGate CLI — compile and convert TypeScript GitHub Actions pipelines (gg)",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "gg": "./dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@gitgate/ci": "workspace:*",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["github-actions", "ci", "typescript", "pipeline", "cli"],
  "homepage": "https://github.com/plsft/gitgate/tree/main/cli#readme",
  "bugs": "https://github.com/plsft/gitgate/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plsft/gitgate.git",
    "directory": "cli"
  },
  "author": "plsft"
}
