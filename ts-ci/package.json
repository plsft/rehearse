{
  "name": "@rehearse/ci",
  "version": "0.6.11",
  "description": "Type-safe GitHub Actions pipelines in TypeScript",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./presets": {
      "import": "./dist/presets/index.js",
      "types": "./dist/presets/index.d.ts"
    },
    "./agent": {
      "import": "./dist/agent/index.js",
      "types": "./dist/agent/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "github-actions",
    "ci",
    "typescript",
    "pipeline"
  ],
  "homepage": "https://github.com/plsft/rehearse/tree/main/ts-ci#readme",
  "bugs": "https://github.com/plsft/rehearse/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plsft/rehearse.git",
    "directory": "ts-ci"
  },
  "author": "plsft"
}
