{
  "name": "example/php-app",
  "description": "Rehearse example: PHP library with PHPUnit",
  "type": "library",
  "license": "Apache-2.0",
  "autoload": {
    "psr-4": {
      "Example\\PhpApp\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Example\\PhpApp\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0"
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse src tests --level 8"
  },
  "config": {
    "sort-packages": true
  }
}
