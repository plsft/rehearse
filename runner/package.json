{
  "name": "@rehearse/runner",
  "version": "0.5.4",
  "description": "Local-first runner for GitHub Actions workflows. Same YAML, fast.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rehearse": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@rehearse/ci": "workspace:*",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "github-actions",
    "ci",
    "runner",
    "local-ci",
    "act-alternative"
  ],
  "homepage": "https://github.com/plsft/rehearse#readme",
  "bugs": "https://github.com/plsft/rehearse/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plsft/rehearse.git",
    "directory": "runner"
  },
  "author": "plsft"
}
